# Quarto generated files
/.quarto/
/_site/
/_site_libs/
**/*.quarto_ipynb
*.html
*_files/

# Keep rendered HTML ignored unless you intentionally publish from docs/
!docs/
!docs/**

# R / RStudio local files
.Rproj.user/
.Rhistory
*.Rhistory
.RData
.Ruserdata

# R package / cache clutter
.Rbuildignore
.Renviron
.Rprofile
renv/library/
renv/staging/
packrat/lib*/
packrat/src/

# OS/editor clutter
.DS_Store
Thumbs.db
.vscode/

# Search engine verification files
!google*.html
!BingSiteAuth.xml